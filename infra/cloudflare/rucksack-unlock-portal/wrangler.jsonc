{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rucksack-unlock-portal",
  "main": "src/index.js",
  "compatibility_date": "2026-06-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "ALLOWED_REPOS": "erniesg/paillette",
    "ALLOWED_EMAILS": ""
  }
}
