# Translation API Keys
# Copy this file to .dev.vars and add your actual API keys

# OpenAI API Key (for Malay translations)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Youdao API Credentials (for Mandarin translations)
# Get from: https://ai.youdao.com/
YOUDAO_APP_KEY=your-youdao-app-key-here
YOUDAO_APP_SECRET=your-youdao-app-secret-here

# Google Translate API Key (for Tamil translations)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_TRANSLATE_API_KEY=your-google-translate-key-here
